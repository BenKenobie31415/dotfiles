        "format": "<span font='13' rise='-1400'>{volume}%</span> <span rise='-500'>{icon}</span> <span rise='0'>{format_source}</span>",
        "format-bluetooth": "<span font='13' rise='-1400'>{volume}%</span> <span rise='-500'>{icon}</span> пЉ” {format_source}",
