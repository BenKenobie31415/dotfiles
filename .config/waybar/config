    "backlight": {
        // "device": "acpi_video1",
        "states": {
            "high": 76,
            "middle": 25,
            "low": 0
        },
        "format": "<span font='13' rise='0'>{percent}%</span> <span font='15' rise='-500'>{icon}</span>",
        "format-icons": ["оҺҚ", "оЏ“", "оЏ‘", "оЏЏ", "оЏҺ", "оЏҚ", "оЏЉ", "оЏ€", "оҺ›"]
